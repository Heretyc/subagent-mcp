    { "name": "edit vscode danger", "op": { "tool": "Edit", "paths": [".vscode/settings.json"], "cwd": "." }, "expected_verdict": "deny" },
    { "name": "config new danger", "op": { "tool": "Write", "paths": ["dist/global-subagent-mcp-config.jsonc"], "cwd": "." }, "expected_verdict": "deny" },
    { "name": "config legacy danger", "op": { "tool": "Write", "paths": ["dist/global-concurrency.jsonc"], "cwd": "." }, "expected_verdict": "deny" },
    { "name": "ordinary write ask", "op": { "tool": "Write", "paths": ["src/new.ts"], "cwd": "." }, "expected_verdict": "ask" },
    { "name": "ordinary edit ask", "op": { "tool": "Edit", "paths": ["src/index.ts"], "cwd": "." }, "expected_verdict": "ask" },
    { "name": "ordinary notebook ask", "op": { "tool": "NotebookEdit", "paths": ["notebook.ipynb"], "cwd": "." }, "expected_verdict": "ask" },
    { "name": "webfetch github safe", "op": { "tool": "WebFetch", "network": [{ "host": "github.com" }], "cwd": "." }, "expected_verdict": "allow" },
    { "name": "webfetch registry safe", "op": { "tool": "WebFetch", "network": [{ "url": "https://registry.npmjs.org/@heretyc/subagent-mcp" }], "cwd": "." }, "expected_verdict": "allow" },
    { "name": "webfetch unknown ask", "op": { "tool": "WebFetch", "network": [{ "host": "example.com" }], "cwd": "." }, "expected_verdict": "ask" },
    { "name": "mcp read split safe", "op": { "tool": "filesystem__Read", "paths": ["README.md"], "cwd": "." }, "expected_verdict": "allow" },
    { "name": "mcp write split ask", "op": { "tool": "filesystem__Write", "paths": ["README.md"], "cwd": "." }, "expected_verdict": "ask" },
    { "name": "mcp edit git split danger", "op": { "tool": "filesystem__Edit", "paths": [".git/config"], "cwd": "." }, "expected_verdict": "deny" },
    { "name": "unknown ask", "op": { "tool": "UnknownTool", "cwd": "." }, "expected_verdict": "ask" },
    { "name": "empty bash ask", "op": { "tool": "Bash", "command": "", "cwd": "." }, "expected_verdict": "ask" },
    { "name": "argv safe", "op": { "tool": "Bash", "argv": ["git", "status", "--short"], "cwd": "." }, "expected_verdict": "allow" },
    { "name": "argv danger", "op": { "tool": "Bash", "argv": ["sudo", "true"], "cwd": "." }, "expected_verdict": "deny" },
    { "name": "resolved path danger", "op": { "tool": "Edit", "paths": ["link/config"], "resolvedPaths": [".ssh/config"], "cwd": "." }, "expected_verdict": "deny" },
    { "name": "allow rule neutral", "op": { "tool": "Bash", "command": "node test.js", "cwd": "." }, "rules": { "allow": ["Bash(node test.js)"] }, "expected_verdict": "allow" },
    { "name": "ask beats allow", "op": { "tool": "Bash", "command": "node test.js", "cwd": "." }, "rules": { "allow": ["Bash(node test.js)"], "ask": ["Bash(node test.js)"] }, "expected_verdict": "ask" },
    { "name": "deny beats ask allow", "op": { "tool": "Bash", "command": "node test.js", "cwd": "." }, "rules": { "allow": ["Bash(node test.js)"], "ask": ["Bash(node test.js)"], "deny": ["Bash(node test.js)"] }, "expected_verdict": "deny" },
    { "name": "danger beats allow", "op": { "tool": "Bash", "command": "sudo true", "cwd": "." }, "rules": { "allow": ["Bash(sudo true)"] }, "expected_verdict": "deny" },
    { "name": "safe escalated by ask", "op": { "tool": "Read", "paths": ["secret.txt"], "cwd": "." }, "rules": { "ask": ["Read(secret.txt)"] }, "expected_verdict": "ask" },
    { "name": "safe escalated by deny", "op": { "tool": "Read", "paths": ["secret.txt"], "cwd": "." }, "rules": { "deny": ["Read(secret.txt)"] }, "expected_verdict": "deny" },
    { "name": "tool content last paren", "op": { "tool": "Bash", "command": "echo (hello)", "cwd": "." }, "rules": { "allow": ["Bash(echo (hello))"] }, "expected_verdict": "allow" },
    { "name": "wildcard bash", "op": { "tool": "Bash", "command": "node scripts/a.mjs", "cwd": "." }, "rules": { "allow": ["Bash(node scripts/*.mjs)"] }, "expected_verdict": "allow" },
    { "name": "wildcard path", "op": { "tool": "Write", "paths": ["tmp/out.txt"], "cwd": "." }, "rules": { "allow": ["Write(tmp/*.txt)"] }, "expected_verdict": "allow" }
  ]
}
