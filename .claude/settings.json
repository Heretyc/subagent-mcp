{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "graphify hook status || echo 'graphify MCP unreachable - run: uv tool install --editable tools/vendor/graphify-local --force && graphify hook install'",
            "timeout": 15
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/hooks/graphify-hint.mjs"
          }
        ]
      }
    ]
  }
}
