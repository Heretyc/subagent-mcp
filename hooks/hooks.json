{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "id": "subagent-mcp-pretool",
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/dist/hooks/orchestration-claude-pretool.js\"",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "id": "subagent-mcp-orchestration-claude",
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/dist/hooks/orchestration-claude.js\""
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "id": "subagent-mcp-session-start",
            "type": "command",
            "command": "node dist/hooks/smcp-activate.js",
            "commandWindows": null,
            "timeout": 5
          }
        ]
      }
    ]
  }
}
